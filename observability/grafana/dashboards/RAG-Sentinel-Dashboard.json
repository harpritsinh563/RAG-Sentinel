{
  "editable": true,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🛡️ Security & Reliability Sentinel",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Prompt Injections Blocked",
      "targets": [ { "expr": "round(sum(increase(rag_guardrail_violation_total[15m])))", "refId": "A" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Hallucinations Caught",
      "targets": [ { "expr": "sum(increase(rag_guardrail_output_tripped_total[15m]))", "refId": "A" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.6 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Vector Similarity Score (Top)",
      "targets": [ { "expr": "rag_vector_top_score", "refId": "A" } ],
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Context Wastage Ratio",
      "targets": [ { "expr": "rate(rag_context_wastage_ratio_sum[1m]) / rate(rag_context_wastage_ratio_count[1m])", "refId": "A" } ],
      "type": "stat"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "⚡ Performance & Latency Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "RAG Latency Stack (Seconds)",
      "targets": [
        { "expr": "rate(rag_vector_search_latency_seconds_sum[1m]) / rate(rag_vector_search_latency_seconds_count[1m])", "legendFormat": "Vector Search", "refId": "A" },
        { "expr": "rate(llm_generation_latency_seconds_sum[1m]) / rate(llm_generation_latency_seconds_count[1m])", "legendFormat": "LLM Total Gen", "refId": "B" }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Ollama Internals (Breakdown)",
      "targets": [
        { "expr": "rate(llm_duration_prompt_eval_seconds_sum[1m]) / rate(llm_duration_prompt_eval_seconds_count[1m])", "legendFormat": "Context Processing", "refId": "A" },
        { "expr": "rate(llm_duration_generation_seconds_sum[1m]) / rate(llm_duration_generation_seconds_count[1m])", "legendFormat": "Token Generation", "refId": "B" },
        { "expr": "rate(llm_duration_load_seconds_sum[1m]) / rate(llm_duration_load_seconds_count[1m])", "legendFormat": "Model Load Time", "refId": "C" }
      ],
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "🧪 RAG Triad & Content Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 15 },
      "id": 7,
      "title": "Faithfulness (Pass vs Fail)",
      "targets": [ { "expr": "sum(increase(rag_eval_faithfulness_total[1h])) by (status)", "legendFormat": "{{status}}", "refId": "A" } ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 15 },
      "id": 8,
      "title": "Context Relevance",
      "targets": [ { "expr": "sum(increase(rag_eval_context_relevance_total[1h])) by (status)", "legendFormat": "{{status}}", "refId": "A" } ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 15 },
      "id": 9,
      "title": "Answer Relevance",
      "targets": [ { "expr": "sum(increase(rag_eval_answer_relevance_total[1h])) by (status)", "legendFormat": "{{status}}", "refId": "A" } ],
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "id": 10,
      "options": { "orientation": "horizontal" },
      "title": "Hot Documents (Chunk Hit Rate)",
      "targets": [ { "expr": "sum(increase(rag_chunk_retrieval_count_total[1h])) by (chunk_id)", "legendFormat": "{{chunk_id}}", "refId": "A" } ],
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "id": 11,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "title": "Empty Retrievals (Out of Domain)",
      "targets": [
        {
          "expr": "sum(increase(rag_retrieval_empty_total[15m]))",
          "legendFormat": "Empty Results",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 12,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Retrieval Window Quality Metrics (Distance Trends)",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "rate(rag_retrieval_distance_avg_sum[1m]) / rate(rag_retrieval_distance_avg_count[1m])",
          "legendFormat": "Average Distance (μ)",
          "refId": "A"
        },
        {
          "expr": "rate(rag_retrieval_distance_stddev_sum[1m]) / rate(rag_retrieval_distance_stddev_count[1m])",
          "legendFormat": "Standard Deviation (σ)",
          "refId": "B"
        },
        {
          "expr": "rate(rag_retrieval_distance_spread_sum[1m]) / rate(rag_retrieval_distance_spread_count[1m])",
          "legendFormat": "Distance Spread (Max - Min)",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 13,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Token Footprint Profile (Granular Breakdown)",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "stacking": { "group": "A", "mode": "normal" } },
          "unit": "tps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(rag_tokens_usage_total[1m])) by (type, model, prompt_version)",
          "legendFormat": "{{model}} - {{type}} ({{prompt_version}})",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 36 },
      "id": 14,
      "options": {
        "orientation": "vertical",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "title": "Pruning Engine Efficiency",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(rag_context_chunks_total[15m])) by (state)",
          "legendFormat": "Chunks {{state}}",
          "refId": "A"
        }
      ],
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 4000 },
              { "color": "red", "value": 8000 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 36 },
      "id": 15,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Avg post-prune context payload mass",
      "targets": [
        {
          "expr": "rate(rag_context_payload_chars_sum[1m]) / rate(rag_context_payload_chars_count[1m])",
          "legendFormat": "Avg Characters",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 44 },
      "id": 16,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Prompt Engine Overheads (Construction Latency vs Prompt Deployment Version)",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "rate(rag_prompt_construction_latency_seconds_sum[1m]) / rate(rag_prompt_construction_latency_seconds_count[1m])",
          "legendFormat": "Template Build Engine ({{version}})",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 17,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "title": "Time to First Token (TTFT)",
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 3.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(rag_llm_ttft_seconds_sum[1m]) / rate(rag_llm_ttft_seconds_count[1m])",
          "legendFormat": "TTFT Avg",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "title": "RAG Observer Sentinel - Elite Dashboard",
  "uid": "rag-sentinel-v2"
}